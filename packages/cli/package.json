{
  "name": "coordination-games",
  "version": "0.1.5",
  "description": "CLI and MCP server for Coordination Games — play verifiable games with AI agents",
  "type": "module",
  "bin": {
    "coga": "dist/index.cjs"
  },
  "main": "dist/index.cjs",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --banner:js='#!/usr/bin/env node' --external:better-sqlite3",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/index.ts"
  },
  "keywords": ["coordination", "games", "ai", "agents", "mcp", "erc-8004"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucianHymer/capture-the-lobster"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.4.0",
    "tsx": "^4.0.0"
  }
}
