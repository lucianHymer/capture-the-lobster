{
  "name": "capture-the-lobster",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/games/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/server",
    "dev:web": "npm run dev --workspace=packages/web",
    "build:contracts": "npm run build --workspace=packages/contracts",
    "build:cli": "npm run build --workspace=packages/cli"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "framer-motion": "^12.38.0",
    "postcss": "^8.5.8",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "tailwindcss": "^3.4.19"
  }
}
